# Athlete OS Messaging Service — Environment Variables
# Copy to .env and fill in values

# API layer (required)
API_BASE_URL=http://localhost:3000/api/v1
API_KEY=dev-local-key

# Discord (default channel — set token and channel ID to activate)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_GUILD_ID=

# Telegram (fallback channel — used if DISCORD_BOT_TOKEN is not set)
TELEGRAM_BOT_TOKEN=

# WhatsApp via Twilio (optional — set all three to activate)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Web chat WebSocket port (default 3001)
WEB_CHAT_PORT=3001

# Coaching engine base URL (for direct calls if needed)
COACHING_ENGINE_URL=http://localhost:3002

# Logging
LOG_LEVEL=info
